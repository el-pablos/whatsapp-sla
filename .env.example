# Application
APP_NAME="WhatsApp SLA - Ayam Petelur"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_USERNAME=default
REDIS_DATABASE=0

# WhatsApp Business API (Legacy - akan dihapus)
WA_API_URL=https://graph.facebook.com/v18.0
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=your_verify_token
WA_APP_ID=your_app_id
WA_APP_SECRET=your_app_secret

# Baileys WhatsApp Service (New - Primary)
BAILEYS_API_URL=http://localhost:3002
BAILEYS_API_KEY=your_baileys_api_key_here
BAILEYS_TIMEOUT=30
BAILEYS_RETRY_ATTEMPTS=3
BAILEYS_RETRY_DELAY=1000
BAILEYS_WEBHOOK_URL=http://localhost/api/whatsapp/webhook

# Baileys Session Management
BAILEYS_SESSION_PATH=app/whatsapp-sessions
BAILEYS_AUTO_RECONNECT=true
BAILEYS_RECONNECT_INTERVAL=5
BAILEYS_MAX_RETRY_COUNT=10

# Baileys Redis Configuration (Dedicated for Baileys events)
BAILEYS_REDIS_HOST=127.0.0.1
BAILEYS_REDIS_PORT=6379
BAILEYS_REDIS_PASSWORD=
BAILEYS_REDIS_DB=1
BAILEYS_REDIS_PREFIX=baileys_

# Baileys Security
BAILEYS_RATE_LIMIT_ENABLED=true
BAILEYS_RATE_LIMIT_MAX=100
BAILEYS_RATE_LIMIT_WINDOW=60

# Baileys Logging
BAILEYS_LOG_LEVEL=info
BAILEYS_LOG_RETENTION_DAYS=30

# GitHub (untuk CI/CD)
GITHUB_TOKEN=your_github_token

# API Bot Token (for Python bot authentication)
API_BOT_TOKEN=your_api_bot_token

# Internal Bot Secret (for Baileys bot communication with Laravel)
BOT_INTERNAL_SECRET=your_bot_internal_secret_here

# Admin phone numbers for WhatsApp bot (comma separated, use international format)
BOT_ADMIN_PHONES=6281234567890,6289876543210
